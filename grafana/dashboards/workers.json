{
  "title": "Maestrio - Workers & Agents",
  "uid": "maestrio-workers",
  "tags": [
    "maestrio"
  ],
  "timezone": "browser",
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "grafana_prometheus"
        },
        "query": "label_values(worker_dispatch_duration_seconds_count, service)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": {
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "name": "worker",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "grafana_prometheus"
        },
        "query": "label_values(worker_dispatch_duration_seconds_count{service=~\"$service\"}, worker)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": {
          "text": "All",
          "value": "$__all"
        }
      }
    ]
  },
  "panels": [
    {
      "title": "Queue Throughput (per min)",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "expr": "sum(rate(worker_dispatch_duration_seconds_count{service=~\"$service\",worker=~\"$worker\"}[5m])) * 60",
          "legendFormat": "Jobs/min"
        }
      ],
      "datasource": {
        "type": "prometheus",
        "uid": "grafana_prometheus"
      }
    },
    {
      "title": "Success Rate",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "targets": [
        {
          "expr": "(1 - sum(rate(worker_dispatch_errors_total{service=~\"$service\",worker=~\"$worker\"}[5m])) / sum(rate(worker_dispatch_duration_seconds_count{service=~\"$service\",worker=~\"$worker\"}[5m]))) * 100",
          "legendFormat": "Success %"
        }
      ],
      "datasource": {
        "type": "prometheus",
        "uid": "grafana_prometheus"
      }
    },
    {
      "title": "Avg Dispatch Latency",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 0
      },
      "targets": [
        {
          "expr": "sum(rate(worker_dispatch_duration_seconds_sum{service=~\"$service\",worker=~\"$worker\"}[5m])) / sum(rate(worker_dispatch_duration_seconds_count{service=~\"$service\",worker=~\"$worker\"}[5m]))",
          "legendFormat": "Avg"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      },
      "datasource": {
        "type": "prometheus",
        "uid": "grafana_prometheus"
      }
    },
    {
      "title": "Queue Depth",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 0
      },
      "targets": [
        {
          "expr": "worker_queue_depth{service=~\"$service\",worker=~\"$worker\"}",
          "legendFormat": "{{worker}}"
        }
      ],
      "datasource": {
        "type": "prometheus",
        "uid": "grafana_prometheus"
      }
    },
    {
      "title": "Dispatch Latency by Worker",
      "description": "Time from queue dequeue to container HTTP response (container startup + routing)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 4
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(worker_dispatch_duration_seconds_bucket{service=~\"$service\",worker=~\"$worker\"}[5m])) by (worker, le))",
          "legendFormat": "{{worker}} p95"
        },
        {
          "expr": "histogram_quantile(0.50, sum(rate(worker_dispatch_duration_seconds_bucket{service=~\"$service\",worker=~\"$worker\"}[5m])) by (worker, le))",
          "legendFormat": "{{worker}} p50"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      },
      "datasource": {
        "type": "prometheus",
        "uid": "grafana_prometheus"
      }
    },
    {
      "title": "Error Rate by Worker",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 4
      },
      "targets": [
        {
          "expr": "sum(rate(worker_dispatch_errors_total{service=~\"$service\",worker=~\"$worker\"}[5m])) by (worker) * 60",
          "legendFormat": "{{worker}}"
        }
      ],
      "datasource": {
        "type": "prometheus",
        "uid": "grafana_prometheus"
      }
    },
    {
      "title": "Avg Triage Execution Time",
      "description": "Average time the container spends running a triage job",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 0,
        "y": 12
      },
      "targets": [
        {
          "expr": "sum(container_execution_duration_seconds_sum{service=~\"$service\",worker=\"triage\"}) / sum(container_execution_duration_seconds_count{service=~\"$service\",worker=\"triage\"})",
          "legendFormat": "Avg"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      },
      "datasource": {
        "type": "prometheus",
        "uid": "grafana_prometheus"
      }
    },
    {
      "title": "Avg Coding Execution Time",
      "description": "Average time the container spends running a coding job",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 4,
        "y": 12
      },
      "targets": [
        {
          "expr": "sum(container_execution_duration_seconds_sum{service=~\"$service\",worker=\"coding\"}) / sum(container_execution_duration_seconds_count{service=~\"$service\",worker=\"coding\"})",
          "legendFormat": "Avg"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      },
      "datasource": {
        "type": "prometheus",
        "uid": "grafana_prometheus"
      }
    },
    {
      "title": "Container Success vs Error",
      "description": "Container job completions by outcome",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 8,
        "y": 12
      },
      "targets": [
        {
          "expr": "sum(rate(container_execution_duration_seconds_count{service=~\"$service\",worker=~\"$worker\",status=\"success\"}[5m])) * 60",
          "legendFormat": "Success/min"
        },
        {
          "expr": "sum(rate(container_execution_duration_seconds_count{service=~\"$service\",worker=~\"$worker\",status=\"error\"}[5m])) * 60",
          "legendFormat": "Error/min"
        }
      ],
      "datasource": {
        "type": "prometheus",
        "uid": "grafana_prometheus"
      }
    },
    {
      "title": "Retry Count",
      "type": "timeseries",
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 16,
        "y": 12
      },
      "targets": [
        {
          "expr": "sum(rate(worker_retries_total{service=~\"$service\",worker=~\"$worker\"}[5m])) by (worker)",
          "legendFormat": "{{worker}}"
        }
      ],
      "datasource": {
        "type": "prometheus",
        "uid": "grafana_prometheus"
      }
    },
    {
      "title": "Container Execution Time by Worker",
      "description": "Full job duration inside the container (clone + agent run + status callback)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 16
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(container_execution_duration_seconds_bucket{service=~\"$service\",worker=~\"$worker\"}[5m])) by (worker, le))",
          "legendFormat": "{{worker}} p95"
        },
        {
          "expr": "histogram_quantile(0.50, sum(rate(container_execution_duration_seconds_bucket{service=~\"$service\",worker=~\"$worker\"}[5m])) by (worker, le))",
          "legendFormat": "{{worker}} p50"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      },
      "datasource": {
        "type": "prometheus",
        "uid": "grafana_prometheus"
      }
    },
    {
      "title": "Container Execution Heatmap",
      "description": "Distribution of container job durations",
      "type": "heatmap",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 16
      },
      "targets": [
        {
          "expr": "sum(increase(container_execution_duration_seconds_bucket{service=~\"$service\",worker=~\"$worker\"}[$__interval])) by (le)",
          "legendFormat": "{{le}}",
          "format": "heatmap"
        }
      ],
      "options": {
        "calculate": false,
        "yAxis": {
          "unit": "s"
        },
        "color": {
          "scheme": "Oranges"
        }
      },
      "datasource": {
        "type": "prometheus",
        "uid": "grafana_prometheus"
      }
    },
    {
      "title": "Triage Runs",
      "description": "Duration of each triage container execution",
      "type": "barchart",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 24
      },
      "datasource": {
        "type": "tempo",
        "uid": "grafana_tempo"
      },
      "targets": [
        {
          "queryType": "traceql",
          "query": "{resource.service.name=~\"$service\" && span.worker=\"triage\"} | select(duration)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ns",
          "color": {
            "mode": "fixed",
            "fixedColor": "blue"
          }
        }
      },
      "options": {
        "orientation": "vertical",
        "showValue": "auto",
        "barWidth": 0.8
      }
    },
    {
      "title": "Coding Runs",
      "description": "Duration of each coding container execution",
      "type": "barchart",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 24
      },
      "datasource": {
        "type": "tempo",
        "uid": "grafana_tempo"
      },
      "targets": [
        {
          "queryType": "traceql",
          "query": "{resource.service.name=~\"$service\" && span.worker=\"coding\"} | select(duration)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ns",
          "color": {
            "mode": "fixed",
            "fixedColor": "orange"
          }
        }
      },
      "options": {
        "orientation": "vertical",
        "showValue": "auto",
        "barWidth": 0.8
      }
    }
  ]
}
