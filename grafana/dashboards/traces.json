{
  "dashboard": {
    "title": "Maestrio - Traces",
    "uid": "maestrio-traces",
    "tags": ["maestrio"],
    "timezone": "browser",
    "refresh": "30s",
    "time": { "from": "now-1h", "to": "now" },
    "panels": [
      {
        "title": "Service Map",
        "type": "nodeGraph",
        "gridPos": { "h": 10, "w": 24, "x": 0, "y": 0 },
        "datasource": { "type": "tempo" },
        "targets": [
          {
            "queryType": "serviceMap"
          }
        ]
      },
      {
        "title": "Trace Search",
        "type": "table",
        "gridPos": { "h": 10, "w": 24, "x": 0, "y": 10 },
        "datasource": { "type": "tempo" },
        "targets": [
          {
            "queryType": "search",
            "serviceName": "maestrio-dashboard"
          }
        ]
      },
      {
        "title": "Latency Distribution by Service",
        "type": "histogram",
        "gridPos": { "h": 8, "w": 24, "x": 0, "y": 20 },
        "datasource": { "type": "tempo" },
        "targets": [
          {
            "queryType": "search",
            "serviceName": "maestrio-dashboard"
          }
        ]
      }
    ]
  }
}
