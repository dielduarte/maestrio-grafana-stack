{
  "title": "Maestrio - Traces",
  "uid": "maestrio-traces",
  "tags": [
    "maestrio"
  ],
  "timezone": "browser",
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "grafana_prometheus"
        },
        "query": "label_values(http_request_duration_seconds_count, service)",
        "refresh": 2,
        "includeAll": true,
        "allValue": ".+",
        "multi": true,
        "current": {
          "text": "All",
          "value": "$__all"
        }
      }
    ]
  },
  "panels": [
    {
      "title": "Service Map",
      "type": "nodeGraph",
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "tempo",
        "uid": "grafana_tempo"
      },
      "targets": [
        {
          "queryType": "serviceMap"
        }
      ]
    },
    {
      "title": "Trace Search",
      "type": "table",
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 10
      },
      "datasource": {
        "type": "tempo",
        "uid": "grafana_tempo"
      },
      "targets": [
        {
          "queryType": "traceql",
          "query": "{resource.service.name=~\"$service\"}"
        }
      ]
    },
    {
      "title": "Error Traces",
      "type": "table",
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 20
      },
      "datasource": {
        "type": "tempo",
        "uid": "grafana_tempo"
      },
      "targets": [
        {
          "queryType": "traceql",
          "query": "{resource.service.name=~\"$service\" && status=error}"
        }
      ]
    },
    {
      "title": "Trace Duration by Operation",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 30
      },
      "datasource": {
        "type": "tempo",
        "uid": "grafana_tempo"
      },
      "targets": [
        {
          "queryType": "traceql",
          "query": "{resource.service.name=~\"$service\"} | rate() by (name)"
        }
      ]
    },
    {
      "title": "Latency Distribution by Service",
      "type": "histogram",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 38
      },
      "datasource": {
        "type": "tempo",
        "uid": "grafana_tempo"
      },
      "targets": [
        {
          "queryType": "traceql",
          "query": "{resource.service.name=~\"$service\"}"
        }
      ]
    }
  ]
}
