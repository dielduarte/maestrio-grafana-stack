{
  "title": "Maestrio - Infrastructure",
  "uid": "maestrio-infra",
  "tags": [
    "maestrio"
  ],
  "timezone": "browser",
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "grafana_prometheus"
        },
        "query": "label_values(process_cpu_seconds_total, service)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": {
          "text": "All",
          "value": "$__all"
        }
      }
    ]
  },
  "panels": [
    {
      "title": "Process CPU Usage",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "expr": "rate(process_cpu_seconds_total{service=~\"$service\"}[5m]) * 100",
          "legendFormat": "CPU %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent"
        }
      },
      "datasource": {
        "type": "prometheus",
        "uid": "grafana_prometheus"
      }
    },
    {
      "title": "RSS Memory",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "targets": [
        {
          "expr": "process_resident_memory_bytes{service=~\"$service\"}",
          "legendFormat": "RSS"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        }
      },
      "datasource": {
        "type": "prometheus",
        "uid": "grafana_prometheus"
      }
    },
    {
      "title": "Heap Used",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 0
      },
      "targets": [
        {
          "expr": "nodejs_heap_size_used_bytes{service=~\"$service\"}",
          "legendFormat": "Heap Used"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        }
      },
      "datasource": {
        "type": "prometheus",
        "uid": "grafana_prometheus"
      }
    },
    {
      "title": "Active Handles",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 0
      },
      "targets": [
        {
          "expr": "nodejs_active_handles_total{service=~\"$service\"}",
          "legendFormat": "Handles"
        }
      ],
      "datasource": {
        "type": "prometheus",
        "uid": "grafana_prometheus"
      }
    },
    {
      "title": "Memory Over Time",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 4
      },
      "targets": [
        {
          "expr": "process_resident_memory_bytes{service=~\"$service\"}",
          "legendFormat": "RSS"
        },
        {
          "expr": "nodejs_heap_size_total_bytes{service=~\"$service\"}",
          "legendFormat": "Heap Total"
        },
        {
          "expr": "nodejs_heap_size_used_bytes{service=~\"$service\"}",
          "legendFormat": "Heap Used"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        }
      },
      "datasource": {
        "type": "prometheus",
        "uid": "grafana_prometheus"
      }
    },
    {
      "title": "Event Loop Lag",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 4
      },
      "targets": [
        {
          "expr": "nodejs_eventloop_lag_seconds{service=~\"$service\"}",
          "legendFormat": "Lag"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      },
      "datasource": {
        "type": "prometheus",
        "uid": "grafana_prometheus"
      }
    },
    {
      "title": "GC Duration",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 12
      },
      "targets": [
        {
          "expr": "rate(nodejs_gc_duration_seconds_sum{service=~\"$service\"}[5m])",
          "legendFormat": "{{kind}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      },
      "datasource": {
        "type": "prometheus",
        "uid": "grafana_prometheus"
      }
    },
    {
      "title": "Active Requests",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 12
      },
      "targets": [
        {
          "expr": "nodejs_active_requests_total{service=~\"$service\"}",
          "legendFormat": "Active Requests"
        }
      ],
      "datasource": {
        "type": "prometheus",
        "uid": "grafana_prometheus"
      }
    }
  ]
}
