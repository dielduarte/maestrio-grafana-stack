{
  "dashboard": {
    "title": "Maestrio - API Performance",
    "uid": "maestrio-api-perf",
    "tags": ["maestrio"],
    "timezone": "browser",
    "refresh": "30s",
    "time": { "from": "now-1h", "to": "now" },
    "panels": [
      {
        "title": "Request Rate (RPM)",
        "type": "stat",
        "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
        "targets": [
          {
            "expr": "sum(rate(http_request_duration_seconds_count{service=\"maestrio-dashboard\"}[5m])) * 60",
            "legendFormat": "RPM"
          }
        ]
      },
      {
        "title": "Error Rate (%)",
        "type": "stat",
        "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
        "targets": [
          {
            "expr": "sum(rate(http_request_duration_seconds_count{service=\"maestrio-dashboard\",status_code=~\"5..\"}[5m])) / sum(rate(http_request_duration_seconds_count{service=\"maestrio-dashboard\"}[5m])) * 100",
            "legendFormat": "Error %"
          }
        ]
      },
      {
        "title": "Avg Latency",
        "type": "stat",
        "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
        "targets": [
          {
            "expr": "sum(rate(http_request_duration_seconds_sum{service=\"maestrio-dashboard\"}[5m])) / sum(rate(http_request_duration_seconds_count{service=\"maestrio-dashboard\"}[5m]))",
            "legendFormat": "Avg"
          }
        ]
      },
      {
        "title": "Latency Percentiles",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
        "targets": [
          {
            "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{service=\"maestrio-dashboard\"}[5m])) by (le))",
            "legendFormat": "p50"
          },
          {
            "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{service=\"maestrio-dashboard\"}[5m])) by (le))",
            "legendFormat": "p95"
          },
          {
            "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{service=\"maestrio-dashboard\"}[5m])) by (le))",
            "legendFormat": "p99"
          }
        ]
      },
      {
        "title": "Request Rate by Endpoint",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
        "targets": [
          {
            "expr": "sum(rate(http_request_duration_seconds_count{service=\"maestrio-dashboard\"}[5m])) by (route) * 60",
            "legendFormat": "{{route}}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "custom": { "stacking": { "mode": "normal" } }
          }
        }
      },
      {
        "title": "Status Code Distribution",
        "type": "piechart",
        "gridPos": { "h": 8, "w": 6, "x": 0, "y": 12 },
        "targets": [
          {
            "expr": "sum(increase(http_request_duration_seconds_count{service=\"maestrio-dashboard\"}[1h])) by (status_code)",
            "legendFormat": "{{status_code}}"
          }
        ]
      },
      {
        "title": "Slowest Endpoints (p95)",
        "type": "table",
        "gridPos": { "h": 8, "w": 18, "x": 6, "y": 12 },
        "targets": [
          {
            "expr": "topk(10, histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{service=\"maestrio-dashboard\"}[5m])) by (route, le)))",
            "legendFormat": "{{route}}",
            "format": "table",
            "instant": true
          }
        ]
      }
    ]
  }
}
